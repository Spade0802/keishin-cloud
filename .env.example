# Database
DATABASE_URL=postgresql://keishin:keishin_dev@localhost:5432/keishin_cloud

# NextAuth.js
AUTH_SECRET=your-secret-here
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Google Cloud Vision API (OCR for scanned PDFs)
# Cloud Runではデフォルトサービスアカウントで自動認証
# ローカル開発ではサービスアカウントキーのパスを指定
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# Next.js
NEXT_PUBLIC_URL=http://localhost:3000

# Stripe (課金)
# テスト用キー: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs (Stripe Dashboardで作成)
# テスト中は ¥0 の価格を作成して設定
STRIPE_PRICE_STANDARD_YEARLY=price_xxx
STRIPE_PRICE_STANDARD_MONTHLY=price_xxx
STRIPE_PRICE_PREMIUM_YEARLY=price_xxx
STRIPE_PRICE_PREMIUM_MONTHLY=price_xxx

# テスト/開発で課金をバイパスする場合はtrue
# 全機能がフリーで使える（Stripe不要）
BYPASS_BILLING=true
